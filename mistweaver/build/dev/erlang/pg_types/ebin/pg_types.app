{application,pg_types,
             [{description,"Erlang library for encoding and decoding postgres data types"},
              {vsn,"0.6.0"},
              {registered,[]},
              {mod,{pg_types_app,[]}},
              {applications,[kernel,stdlib]},
              {env,[]},
              {modules,[pg_array,pg_bit_string,pg_boolean,pg_circle,pg_date,
                        pg_enum,pg_float4,pg_float8,pg_hstore,pg_inet,pg_int2,
                        pg_int4,pg_int8,pg_interval,pg_json,pg_jsonb,pg_line,
                        pg_line_segment,pg_macaddr,pg_math,pg_name,pg_numeric,
                        pg_oid,pg_path,pg_point,pg_polygon,pg_range,pg_raw,
                        pg_record,pg_tid,pg_time,pg_timestamp,pg_timestampz,
                        pg_tsvector,pg_types,pg_types_app,pg_types_server,
                        pg_types_sup,pg_uuid]},
              {licenses,["Apache-2.0"]},
              {links,[{"Github","https://github.com/tsloughter/pg_types"}]}]}.
